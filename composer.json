{
    "name": "jagdpanzer4/guerrilla",
    "description": "Guerrilla – Concrete CMS 9.5 project template",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "concrete5/core": "^9.5"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "phpunit/phpunit": "^10.0"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "concrete5/core-installer": true
        }
    },
    "extra": {
        "installer-paths": {
            "concrete/": ["concrete5/core"]
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
